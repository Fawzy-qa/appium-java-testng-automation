<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" verbose="1">
    <!--
      verbose="1" prints test method names to console.
      Do NOT enable parallel="methods" unless you have multiple physical devices
      or use a device farm. A single Appium server + one device cannot run
      mobile tests in parallel safely.
    -->

    <listeners>
        <!-- Allure TestNG adapter: generates result JSON files in target/allure-results -->
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>

        <!-- Custom screenshot capture on failure/skipped -->
        <listener class-name="mobileproject.utils.ScreenshotListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="mobileproject.tests.LoginTests"/>
        </classes>
    </test>

    <test name="User Dashboard Tests">
        <classes>
            <class name="mobileproject.tests.UserDashboardTests"/>
        </classes>
    </test>
</suite>